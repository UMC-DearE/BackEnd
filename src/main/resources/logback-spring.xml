<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 공통 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId}] [userId=%X{userId}] [%X{method} %X{uri}] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- DEV -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.deare.backend" level="DEBUG"/>
        <logger name="p6spy" level="INFO"/>
        <logger name="com.p6spy" level="INFO"/>
    </springProfile>

    <!-- PROD -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.deare.backend" level="INFO"/>
        <logger name="p6spy" level="OFF"/>
        <logger name="com.p6spy" level="OFF"/>
    </springProfile>

    <!-- default -->
    <springProfile name="default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
